# Copy to .env and fill in the keys you have. Each stage will fail with a clear
# message if its required key is missing — provision as you go.

# Stage 1 (plan) & Stage 7 (metadata)
ANTHROPIC_API_KEY=

# Stage 2 (images) & Stage 3 (clips) — single key, many models
FAL_KEY=

# Stage 5 (audio) — SFX layers
ELEVENLABS_API_KEY=

# Stage 5 audio: music beds are generated via fal (CassetteAI / Beatoven),
# so no extra key is needed — FAL_KEY above covers it.

# Optional overrides
FIREFLY_PLAN_MODEL=claude-sonnet-4-6
FIREFLY_METADATA_MODEL=claude-sonnet-4-6
FIREFLY_IMAGE_MODEL=fal-ai/flux-pro/v1.1
FIREFLY_VIDEO_MODEL=fal-ai/kling-video/v3/pro/image-to-video
FIREFLY_MUSIC_MODEL=cassetteai/music-generator
